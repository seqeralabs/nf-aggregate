process {
    withName: 'NORMALIZE_BENCHMARK_JSONL' {
        publishDir = [
            path: { "${params.outdir}/benchmark_report" },
            mode: 'copy',
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                if (filename.equals('jsonl_bundle')) return 'jsonl_bundle'
                return "jsonl_bundle/${filename}"
            }
        ]
    }

    withName: 'AGGREGATE_BENCHMARK_REPORT_DATA' {
        publishDir = [
            path: { "${params.outdir}/benchmark_report" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'RENDER_BENCHMARK_REPORT' {
        publishDir = [
            path: { "${params.outdir}/benchmark_report" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
