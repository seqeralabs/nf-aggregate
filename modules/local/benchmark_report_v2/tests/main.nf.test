nextflow_process {
    name "Test Process BENCHMARK_REPORT_V2"
    script "../main.nf"
    process "BENCHMARK_REPORT_V2"

    test("Should generate benchmark report from test data") {
        when {
            params {
                outdir = "tests/results"
            }
            process {
                """
                input[0] = file("${moduleDir}/tests/data", checkIfExists: true)
                input[1] = []
                input[2] = file("${projectDir}/assets/brand.yml", checkIfExists: true)
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.html.get(0)).exists()
            assert path(process.out.html.get(0)).text.contains("Pipeline benchmarking report")
            assert path(process.out.versions.get(0)).exists()
        }
    }
}
